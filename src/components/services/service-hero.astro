---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<div class="relative z-[2] layout-wrapper">
  <div class="flex flex-col gap-5 pt-10 max-w-[600px]">
    <nav class="flex items-center gap-2 text-caption-sm text-[var(--neutral-500)]">
      <a href="/" class="text-[var(--neutral-500)] hover:text-[var(--brand-accent-dark)] transition-colors no-underline">Inicio</a>
      <span>/</span>
      <a href="/#servicios" class="text-[var(--neutral-500)] hover:text-[var(--brand-accent-dark)] transition-colors no-underline">Servicios</a>
      <span>/</span>
      <span class="font-semibold text-[var(--brand-accent-dark)]">{title}</span>
    </nav>
    <h1 class="font-heading text-h1 text-[var(--neutral-900)]">{title}</h1>
    <p class="font-editorial italic text-subtitle text-[var(--neutral-900)]" set:html={description} />
  </div>
</div>
