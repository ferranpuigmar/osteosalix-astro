---
import { Icon } from "astro-icon/components";

export interface Treatment {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  treatment: Treatment;
}

const { treatment } = Astro.props;
---

<div class="bg-white rounded-[16px] shadow-[0_4px_20px_rgba(0,0,0,0.04)] p-6 flex gap-4">
  <div class="w-6 h-6 text-[var(--brand-accent)]">
    <Icon name={`lucide:${treatment.icon}`} size={24} />
  </div>
  <div class="flex flex-col gap-[6px]">
    <h3 class="font-heading text-[18px] font-[800] text-[var(--neutral-900)]">{treatment.title}</h3>
    <p class="text-body-sm text-[var(--neutral-600)]">{treatment.description}</p>
  </div>
</div>
