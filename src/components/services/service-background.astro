---
interface Props {
  image: string;
  alt: string;
}

const { image, alt } = Astro.props;
---

<div class="relative">
  <div class="absolute inset-0 overflow-hidden" style="max-height:500px">
    <img
      src={image}
      alt={alt}
      class="w-full h-full object-cover opacity-[0.38]"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-[#F7F5F2] via-[#F7F5F2]/0 via-40% to-[#F7F5F2]/0" />
  </div>
  <div class="relative">
    <slot />
  </div>
</div>
