---
import LayoutWrapper from '../layout/layout-wrapper.astro';
import ServiceCard from '../shared/service-card.astro';

interface CenterService {
  slug: string;
  title: string;
  description: string;
  cardImage?: string;
}

interface Props {
  services: CenterService[];
}

const { services } = Astro.props;

const mtOffsets = ['', 'lg:mt-12', '', 'lg:mt-12'];
---

<section class="bg-[var(--bg-canvas)] py-[60px] lg:py-[80px] overflow-hidden">
  <LayoutWrapper>
    <div class="flex flex-col gap-5 mb-12 lg:mb-[60px]">
      <span class="text-overline-sm text-xs text-[var(--brand-accent)]">Servicios disponibles</span>
      <h2 class="text-h3">Tratamientos en este centro</h2>
    </div>
    <div class="flex flex-wrap items-start gap-6 lg:gap-x-[30px]">
      {services.map((service, i) => (
        <div class={`w-full lg:w-[calc(25%-22.5px)] ${mtOffsets[i] ?? ''}`}>
          <ServiceCard
            title={service.title}
            description={service.description}
            image={service.cardImage ?? ''}
            link={`/servicios/${service.slug}`}
            alt={i % 2 !== 0}
          />
        </div>
      ))}
    </div>
  </LayoutWrapper>
</section>
