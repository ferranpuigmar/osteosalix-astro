---
import { Leaflet, CreateLeafletIcon } from "astro-leaflet";

interface CenterCoords {
  lat: number;
  lng: number;
}

interface Props {
  center: CenterCoords;
}

const { center } = Astro.props;
const id = "center-map";
---

<div id={id} class="h-[300px] lg:absolute lg:inset-0 lg:z-0 lg:h-full" data-lat={center.lat} data-lng={center.lng}>
  <CreateLeafletIcon
    name="map-pin-gold"
    options={{
      className: "leaflet-marker-gold",
      iconSize: [40, 40],
      iconAnchor: [30, 30],
      html: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
    }}
  />
  <Leaflet
    style="width:100%;height:100%;"
    options={{
      tileLayer: "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png",
      tileLayerOptions: {
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
        subdomains: "abcd",
        maxZoom: 19,
      },
      center: [center.lat, center.lng - 0.00113],
      zoom: 18,
      mapOptions: {
        dragging: true,
        scrollWheelZoom: false,
        attributionControl: false,
      },
      markers: [
        {
          latlng: [center.lat, center.lng],
          options: { title: center.name },
          astroIconName: "map-pin-gold",
        },
      ],
    }}
  />
</div>

<style>
  :global(.leaflet-top.leaflet-left) {
    left: auto;
    right: 10px;
  }

  :global(.leaflet-marker-gold) {
    background: #d4a374;
    width: 60px;
    height: 60px;
    border-radius: 30px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
    border: 0;
  }
</style>

<script>
  const wrapper = document.getElementById("center-map");
  if (!wrapper) throw new Error("Missing #center-map");
  const leafletEl = wrapper.querySelector("astro-leaflet");
  if (!leafletEl) throw new Error("Missing astro-leaflet element");

  const lat = parseFloat(wrapper.dataset.lat);
  const lng = parseFloat(wrapper.dataset.lng);

  function syncCenter() {
    if (!leafletEl.leafletElement) return;
    const isDesktop = window.matchMedia("(width >= 1024px)").matches;
    leafletEl.leafletElement.setView(isDesktop ? [lat, lng - 0.00113] : [lat, lng], 18, { animate: false });
  }

  if (leafletEl.leafletElement) {
    syncCenter();
  } else {
    customElements.whenDefined("astro-leaflet").then(() => {
      syncCenter();
    });
  }

  window.addEventListener("resize", syncCenter);
</script>
