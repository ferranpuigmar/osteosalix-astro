---
import { Icon } from "astro-icon/components";
import { Leaflet, CreateLeafletIcon } from "astro-leaflet";
import type { CenterData } from "@/data/centers";
import LayoutWrapper from "../layout/layout-wrapper.astro";

interface Props {
	center: CenterData;
}

const { center } = Astro.props;
const mapCenter: [number, number] = [center.lat, center.lng - 0.00113];
---

<section class="relative h-[440px] lg:h-[550px] overflow-hidden mt-[90px] flex items-center">
	<div class="absolute inset-0 z-0">
		<CreateLeafletIcon
			name="map-pin-gold"
			options={{
				className: "leaflet-marker-gold",
				iconSize: [40, 40],
				iconAnchor: [30, 30],
				html: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
			}}
		/>
		<div id="center-map" class="h-full">
			<Leaflet
				style="width:100%;height:100%;"
				options={{
					tileLayer: "https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png",
					tileLayerOptions: {
						attribution:
							'&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
						subdomains: "abcd",
						maxZoom: 19,
					},
					center: mapCenter,
					zoom: 18,
					mapOptions: {
						scrollWheelZoom: false,
						attributionControl: false,
					},
					markers: [
						{
							latlng: [center.lat, center.lng],
							options: { title: center.name },
							astroIconName: "map-pin-gold",
						},
					],
				}}
			/>
		</div>
	</div>
	<LayoutWrapper>
		<div class="relative z-[3] flex items-center pointer-events-none">
			<div
				class="w-full lg:w-[531px] bg-white rounded-[60px_16px_60px_16px] shadow-[0_10px_40px_rgba(0,0,0,0.08)] p-10 flex flex-col gap-6 pointer-events-auto"
			>
				<nav class="flex items-center gap-2 text-body-xs">
					<a
						href="/"
						class="text-[var(--neutral-600)] hover:text-[var(--brand-primary)] transition-colors no-underline"
						>Inicio</a
					>
					<span class="text-[var(--neutral-600)]">/</span>
					<a
						href="/#centros"
						class="text-[var(--neutral-600)] hover:text-[var(--brand-primary)] transition-colors no-underline"
						>Centros</a
					>
					<span class="text-[var(--neutral-600)]">/</span>
					<span class="font-semibold text-[var(--brand-primary)]"
						>{center.name}</span
					>
				</nav>

				<h1
					class="font-heading text-[48px] font-[500] leading-[1.1] tracking-[-1px] text-[var(--neutral-900)]"
				>
					{center.name}
				</h1>

				<p class="text-body text-[var(--neutral-600)] max-w-[370px]">
					{center.subtitle}
				</p>

				<div class="flex flex-col gap-4">
					<div class="flex items-center gap-3">
						<Icon
							name="lucide:map-pin"
							size={18}
							class="text-[var(--brand-accent)] shrink-0"
						/>
						<span class="text-body-sm text-[var(--neutral-600)]"
							>{center.address}</span
						>
					</div>
					<div class="flex items-center gap-3">
						<Icon
							name="lucide:phone"
							size={18}
							class="text-[var(--brand-accent)] shrink-0"
						/>
						<span class="text-body-sm text-[var(--neutral-600)]"
							>{center.phone}</span
						>
					</div>
					<div class="flex items-center gap-3">
						<Icon
							name="lucide:clock-3"
							size={18}
							class="text-[var(--brand-accent)] shrink-0"
						/>
						<span class="text-body-sm text-[var(--neutral-600)]"
							>{center.hours}</span
						>
					</div>
				</div>
			</div>
		</div>
	</LayoutWrapper>
</section>

<style>
	section :global(.leaflet-top.leaflet-left) {
		left: auto;
		right: 10px;
	}

	:global(.leaflet-marker-gold) {
		background: #d4a374;
		width: 60px;
		height: 60px;
		border-radius: 30px;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
		border: 0;
	}
</style>

<script>
	const wrapper = document.getElementById("center-map");
	if (!wrapper) throw new Error("Missing #center-map");
	const leafletEl = wrapper.querySelector("leaflet");
	if (!leafletEl) throw new Error("Missing leaflet element");

	let wheelTimer: ReturnType<typeof setTimeout> | null = null;

	leafletEl.addEventListener("map-ready", (e: Event) => {
		const map = (e as CustomEvent).detail.map;
		const container = map.getContainer();

		container.addEventListener("mouseenter", () => {
			wheelTimer = setTimeout(() => {
				map.scrollWheelZoom.enable();
			}, 800);
		});

		container.addEventListener("mouseleave", () => {
			if (wheelTimer) clearTimeout(wheelTimer);
			map.scrollWheelZoom.disable();
		});
	});
</script>
