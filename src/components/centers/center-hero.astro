---
import { Icon } from "astro-icon/components";
import type { CenterData } from "@/data/centers";
import LayoutWrapper from "../layout/layout-wrapper.astro";
import CenterMap from "./center-map.astro";

interface Props {
	center: CenterData;
}

const { center } = Astro.props;
---

<section class="relative pt-[60px] lg:pt-0 lg:overflow-hidden lg:h-[550px] lg:flex lg:items-center">
	<LayoutWrapper class="relative z-[3] max-lg:px-0 lg:pointer-events-none">
		<div class="lg:pointer-events-none lg:flex lg:items-center">
			<div
				class="w-full lg:w-[531px] bg-white lg:rounded-[60px_16px_60px_16px] shadow-[0_10px_40px_rgba(0,0,0,0.08)] p-10 flex flex-col gap-6 lg:pointer-events-auto"
			>
				<nav class="flex items-center gap-2 text-body-xs">
					<a
						href="/"
						class="text-[var(--neutral-600)] hover:text-[var(--brand-primary)] transition-colors no-underline"
						>Inicio</a
					>
					<span class="text-[var(--neutral-600)]">/</span>
					<a
						href="/#donde-estamos"
						class="text-[var(--neutral-600)] hover:text-[var(--brand-primary)] transition-colors no-underline"
						>Centros</a
					>
					<span class="text-[var(--neutral-600)]">/</span>
					<span class="font-semibold text-[var(--brand-primary)]"
						>{center.name}</span
					>
				</nav>

				<h1
					class="font-heading text-[48px] font-[500] leading-[1.1] tracking-[-1px] text-[var(--neutral-900)]"
				>
					{center.name}
				</h1>

				<p class="text-body text-[var(--neutral-600)] max-w-[370px]">
					{center.subtitle}
				</p>

				<div class="flex flex-col gap-4">
					<div class="flex items-center gap-3">
						<Icon
							name="lucide:map-pin"
							size={18}
							class="text-[var(--brand-accent)] shrink-0"
						/>
						<span class="text-body-sm text-[var(--neutral-600)]"
							>{center.address}</span
						>
					</div>
					<div class="flex items-center gap-3">
						<Icon
							name="lucide:phone"
							size={18}
							class="text-[var(--brand-accent)] shrink-0"
						/>
						<span class="text-body-sm text-[var(--neutral-600)]"
							>{center.phone}</span
						>
					</div>
					<div class="flex items-center gap-3">
						<Icon
							name="lucide:clock-3"
							size={18}
							class="text-[var(--brand-accent)] shrink-0"
						/>
						<span class="text-body-sm text-[var(--neutral-600)]"
							>{center.hours}</span
						>
					</div>
				</div>
			</div>
		</div>
	</LayoutWrapper>

	<CenterMap center={center} />
</section>
