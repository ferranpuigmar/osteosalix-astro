---
import { Icon } from "astro-icon/components";
import LayoutWrapper from "../layout/layout-wrapper.astro";
import Text from "../shared/text.astro";
import CenterMap from "./center-map.astro";

interface CenterEntry {
  name: string;
  subtitle: string;
  address: string;
  phone: string;
  hours: string;
  lat: number;
  lng: number;
}

interface Props {
  center: CenterEntry;
}

const { center } = Astro.props;
---

<section class="relative pt-[60px] lg:pt-0 lg:overflow-hidden lg:h-[550px] lg:flex lg:items-center">
	<LayoutWrapper class="relative z-[3] max-lg:px-0 lg:pointer-events-none">
		<div class="lg:pointer-events-none lg:flex lg:items-center">
			<div
				class="w-full lg:w-[531px] bg-white lg:rounded-[60px_16px_60px_16px] shadow-[0_10px_40px_rgba(0,0,0,0.08)] p-10 flex flex-col gap-6 lg:pointer-events-auto"
			>
				<nav class="flex items-center gap-2">
					<Text
						tag="a"
						href="/"
						size="body-xs"
						color="neutral-600"
						class="no-underline hover:text-brand-primary transition-colors"
					>
						Inicio
					</Text>
					<Text tag="span" size="body-xs" color="neutral-600">/</Text>
					<Text
						tag="a"
						href="/#donde-estamos"
						size="body-xs"
						color="neutral-600"
						class="no-underline hover:text-brand-primary transition-colors"
					>
						Centros
					</Text>
					<Text tag="span" size="body-xs" color="neutral-600">/</Text>
					<Text
						tag="span"
						size="body-xs"
						color="brand-primary"
						class="font-semibold"
					>
						{center.name}
					</Text>
				</nav>

				<Text
					tag="h1"
					size="h1"
					color="neutral-900"
					class="text-[48px] leading-[1.1]"
				>
					{center.name}
				</Text>

				<Text size="body" color="neutral-600" class="max-w-[370px]">
					{center.subtitle}
				</Text>

				<div class="flex flex-col gap-4">
					<div class="flex items-center gap-3">
						<Icon
							name="lucide:map-pin"
							size={18}
							class="text-[var(--brand-accent)] shrink-0"
						/>
						<Text
							tag="span"
							size="body-sm"
							color="neutral-600"
							set:html={center.address}
						/>
					</div>
					<div class="flex items-center gap-3">
						<Icon
							name="lucide:phone"
							size={18}
							class="text-[var(--brand-accent)] shrink-0"
						/>
						<Text tag="span" size="body-sm" color="neutral-600">
							{center.phone}
						</Text>
					</div>
					<div class="flex items-center gap-3">
						<Icon
							name="lucide:clock-3"
							size={18}
							class="text-[var(--brand-accent)] shrink-0"
						/>
						<Text tag="span" size="body-sm" color="neutral-600">
							{center.hours}
						</Text>
					</div>
				</div>
			</div>
		</div>
	</LayoutWrapper>

	<CenterMap center={center} />
</section>
