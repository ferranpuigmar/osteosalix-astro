---
import LayoutWrapper from '../layout/layout-wrapper.astro';
import CenterCard from './center-card.astro';

interface CenterCardData {
  slug: string;
  name: string;
  address: string;
  phone: string;
  image?: string;
}

interface Props {
  title: string;
  subtitle: string;
  centers: CenterCardData[];
}

const { title, subtitle, centers } = Astro.props;
---

<section id="donde-estamos" class="bg-neutral-200 overflow-hidden py-[60px] lg:py-[80px]">
  <LayoutWrapper>
    <div class="flex flex-col items-center gap-4 mb-10 lg:mb-[70px]">
      <span class="text-overline-sm text-xs text-[var(--brand-accent)]">{title}</span>
      <h2 class="text-h2 text-center">{subtitle}</h2>
    </div>
    <div class="flex flex-col lg:flex-row items-center justify-center gap-6 lg:gap-12">
      {
        centers.map((center, i) => (
          <CenterCard
            name={center.name}
            address={center.address}
            phone={center.phone}
            image={center.image ?? ''}
            link={`/centro/${center.slug}`}
            alt={i % 2 !== 0}
          />
        ))
      }
    </div>
  </LayoutWrapper>
</section>
