---
interface Props {
  variant?: 'primary' | 'outline' | 'submit';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  target?: string;
  rel?: string;
}

const {
  variant = 'primary',
  href,
  type = 'button',
  class: className,
  target,
  rel,
} = Astro.props;

const baseClass =
  'inline-flex items-center justify-center gap-2 px-8 py-4 rounded-[28px] text-sm font-bold tracking-[2px] uppercase transition-all duration-150 no-underline cursor-pointer';

const variantClasses: Record<string, string> = {
  primary:
    'bg-brand-primary text-white hover:opacity-90',
  outline:
    'bg-transparent text-brand-dark border-2 border-brand-dark hover:bg-brand-dark hover:text-white',
  submit:
    'w-full h-14 bg-brand-primary text-white text-base font-semibold hover:opacity-90',
};

const Tag = href ? 'a' : 'button';
---

{
  href ? (
    <a
      href={href}
      target={target}
      rel={rel}
      class:list={[baseClass, variantClasses[variant], className]}
    >
      <slot />
    </a>
  ) : (
    <button
      type={type}
      class:list={[baseClass, variantClasses[variant], className]}
    >
      <slot />
    </button>
  )
}
