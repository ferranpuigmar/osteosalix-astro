---
import { siteConfig } from '@/data/site-config';
import Container from './container.astro';

import ContactForm from './contact-form.astro';

import GoogleMaps from './google-maps.astro';
---

<footer class="w-full bg-primary-light p-0 relative z-[1]">
  <div id="contactar" class="px-0 py-16">
    <Container>
      <h2 class="mb-8 w-full text-center text-3xl tracking-wide leading-tight md:text-4xl pb-4 font-[mobile-sans]">
        <span>¿En qué te podemos ayudar?</span>
      </h2>
      <ContactForm />
    </Container>
  </div>

  <section id="donde-estamos" class="map-section mt-4 pb-36 bg-cover bg-no-repeat bg-[position:0_0] relative" style="background-image: url('/images/bg-map.jpg');">
    <Container class="flex items-center flex-col relative z-[1]">
      <h2 class="text-4xl leading-[2.5rem] tracking-wide text-center mx-auto relative inline-block before:content-none after:content-none md:before:content-[''] md:after:content-[''] md:before:w-[150px] md:after:w-[150px] md:before:h-px md:after:h-px md:before:bg-black md:after:bg-black md:before:opacity-30 md:after:opacity-30 md:before:absolute md:after:absolute md:before:top-1/2 md:after:top-1/2 md:before:right-[calc(100%+10px)] md:after:left-[calc(100%+10px)]">¿Dónde estamos?</h2>
      <p class="mt-6 mb-6 text-center font-[mobile-sans]">{siteConfig.address.full}</p>
      <div class="google-maps shadow-2xl gap-5 flex flex-col justify-center items-center w-full h-[400px] md:w-4/5">
        <GoogleMaps />
      </div>
    </Container>
  </section>
</footer>

<style>
  .map-section::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    height: 70%;
    width: 100%;
    z-index: 0;
    background: linear-gradient(176deg, #C9EAD9 18%, rgba(201, 234, 217, 0));
  }
</style>
