---
import { Icon } from "astro-icon/components";
import { cn } from '@/lib/utils';
import type { HomeData } from '@/server/domain/models';
import LayoutWrapper from "../layout/layout-wrapper.astro";
import Text from "../shared/text.astro";
import Button from "../shared/button.astro";

interface Props {
	data: HomeData["heroSection"];
	whatsappNumber: string;
}

const { data, whatsappNumber } = Astro.props;
---

<section
	class={cn(
		"relative z-0 w-full overflow-hidden bg-[var(--bg-canvas)]",
		"md:h-[700px] pt-[60px] md:pt-[90px] pb-16 md:pb-0"
	)}
>
	<div class="absolute inset-0 opacity-[0.27]">
		<img src={data.bgOverlayUrl} alt="" class="w-full h-full object-cover" />
	</div>

	<LayoutWrapper
		class={cn(
			"relative z-20 h-full flex items-center",
			"justify-center lg:justify-between"
		)}
	>
		<div
			class={cn(
				"relative z-20 h-full flex items-center justify-between",
				"md:items-start md:mt-6 lg:mt-16"
			)}
		>
			<div
				class={cn(
					"flex flex-col items-center justify-center gap-8",
					"max-w-[600px] mx-auto"
				)}
			>
				<Text
					tag="span"
					size="overline-sm"
					color="text-inverse"
					class={cn(
						"inline-block px-4 py-2 mt-3 md:mt-0 rounded-[20px] text-center",
						"bg-(--brand-accent)/70 text-[16px] text-xs w-auto"
					)}
				>
					{data.badge}
				</Text>

				<Text
					tag="h1"
					size="display"
					color="brand-dark"
					class={cn(
						"tracking-normal text-center max-w-none font-bold",
						"md:text-[40px] lg:text-[64px]"
					)}
				>
					{data.title}
				</Text>

				<Text
					tag="p"
					size="body-lg"
					class={cn(
						"text-center text-lg lg:text-xl text-brand-dark",
						"leading-[1.6] lg:leading-[1.7] max-w-[540px]"
					)}
				>
					{data.description}
				</Text>

				<div class="flex flex-wrap items-center justify-center gap-4">
					<Button
						href={`https://wa.me/${whatsappNumber}`}
						class={cn(
							"w-full md:w-auto gap-2 px-8 h-auto py-4",
							"rounded-[28px] text-sm font-bold tracking-[2px] uppercase"
						)}
					>
						<Icon name="lucide:message-circle" size={16} />WhatsApp
					</Button>
					<Button
						href="#sobre-nosotros"
						variant="outline"
						class={cn(
							"w-full md:w-auto gap-2 px-8 h-auto py-4",
							"rounded-[28px] text-sm font-bold tracking-[2px] uppercase"
						)}
					>
						Conócenos
					</Button>
				</div>
			</div>
			
		</div>
    <div
			class={cn(
				"relative hidden lg:block z-30 right-0",
				"w-[calc(500/1440*100%)] max-w-[500px] h-[580px]"
			)}
		>
			<img
				src={data.heroImageUrl}
				alt=""
				class="w-full h-full object-cover rounded-tl-[120px] rounded-tr-[20px] rounded-br-[120px] rounded-bl-[20px]"
			/>
		</div>
	</LayoutWrapper>

	<div
		class={cn(
			"absolute inset-0 bg-gradient-to-b from-[#8A9F86] via-[#9DAF99] via-50% to-[#F7F5F2]",
			"opacity-[0.48] hidden md:block"
		)}
	>
	</div>

	<div
		class={cn(
			"absolute inset-0 bg-gradient-to-l from-[#F7F5F2] from-0% via-[#F7F5F2]/88 via-40% to-[#F7F5F2]/0 to-70%",
			"hidden md:block"
		)}
	>
	</div>

	<svg
		class="absolute bottom-0 left-0 w-full h-[100px] z-10 hidden md:block"
		viewBox="0 0 1440 100"
		preserveAspectRatio="none"
		fill="none"
	>
		<path
			d="M0 0 q360 100 720 50 q360 -50 720 10 L1440 100 L0 100 Z"
			class="fill-[var(--bg-canvas)]"></path>
	</svg>
</section>
