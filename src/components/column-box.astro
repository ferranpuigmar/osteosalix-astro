---
import { Image } from 'astro:assets';

interface Props {
  text: string;
  image: string;
  position?: 'left' | 'right';
  link: string;
  color?: 'main' | 'black';
}

const { text, image, position = 'left', link, color = 'main' } = Astro.props;
const plainText = text.replace(/<[^>]+>/g, '').trim();
---

<div class="w-full min-h-[300px] flex grid-rows-1 grid-cols-2 items-center justify-center relative first:mb-5 md:grid md:min-h-[500px] first:md:mb-0">
  <div class={`absolute w-full h-full top-0 left-0 z-[1] opacity-20 md:relative md:opacity-100 ${position === 'right' ? 'order-1 md:order-1' : ''}`}>
    <Image
      src={image}
      alt={plainText}
      width={1200}
      height={800}
      class="object-cover object-center w-full h-full"
    />
  </div>
  <div class={`flex justify-center items-center h-full relative z-[2] ${position === 'right' ? 'order-0' : ''}`}>
    <h3 class={`mx-[10%] text-center text-xl tracking-wider leading-relaxed opacity-100 z-[2] md:text-4xl md:opacity-100 lg:mx-[25%] ${color === 'main' ? 'md:text-brand-primary' : ''}`}>
      <a href={link} class="no-underline text-inherit" set:html={text} />
    </h3>
  </div>
</div>
