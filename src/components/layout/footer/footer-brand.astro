---
import { Icon } from "astro-icon/components";
import LogoIcon from "@/components/shared/logo-icon.astro";
---

<div class="flex flex-col gap-6 w-full lg:w-[320px]">
  <div class="flex items-center gap-3">
    <LogoIcon class="w-10 h-10 text-white" />
    <span
      class="font-heading text-2xl tracking-[1px] text-[var(--text-inverse)]"
    >osteo<span class="text-white/67">salix</span></span>
  </div>
  <p class="font-editorial text-[15px] leading-[1.7] text-[var(--footer-text)]">
    Osteopatía y fisioterapia en Sant Cugat.<br />Cuidamos de tu salud
    con dedicación<br />y profesionalidad.
  </p>
  <div class="flex gap-3">
    <a
      href="#"
      class="w-11 h-11 rounded-full bg-white/15 flex items-center justify-center hover:bg-white/25 transition-colors"
      aria-label="Facebook"
    >
      <Icon name="lucide:facebook" class="w-5 h-5 text-white" />
    </a>
    <a
      href="#"
      class="w-11 h-11 rounded-full bg-white/15 flex items-center justify-center hover:bg-white/25 transition-colors"
      aria-label="Instagram"
    >
      <Icon name="lucide:instagram" class="w-5 h-5 text-white" />
    </a>
  </div>
</div>
