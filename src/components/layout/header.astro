---
import HeaderIsland from '@/islands/header';
import { getHeader } from '@/pages/api/header';
import type { LogoData } from '@/server/types';
const pathname = Astro.url.pathname;
const { navigation, logoTextEnd, logoTextStart, logo: logoUrl, whatsappNumber } = await getHeader();

const logo: LogoData = {
    textStart: logoTextStart,
    textEnd: logoTextEnd,
    logo: logoUrl,
};
---

<HeaderIsland pathname={pathname} navigation={navigation} logo={logo} whatsappNumber={whatsappNumber} client:load />
