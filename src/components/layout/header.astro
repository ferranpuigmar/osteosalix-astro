---
import HeaderIsland from '@/islands/header';
import { getHeader } from '@/pages/api/header';
import { inlineSvg } from '@/server/infrastructure/strapi-url';
const pathname = Astro.url.pathname;
const { navigation, logoTextEnd, logoTextStart, logo: logoUrl, whatsappNumber } = await getHeader();

const logoSvg = await inlineSvg(logoUrl);
---

<HeaderIsland pathname={pathname} navigation={navigation} logoSvg={logoSvg} textStart={logoTextStart} textEnd={logoTextEnd} whatsappNumber={whatsappNumber} client:load />
