---
import { Image } from 'astro:assets';
import type { HomeData } from '@/server/repositories/types';

interface Props {
  data: HomeData['heroSection'];
}

const { data } = Astro.props;
---

<section class="pb-8 pt-16 h-screen bg-white flex items-center justify-center w-full overflow-hidden relative font-[mobile-sans]">
  <div class="relative z-[2] flex items-center w-full flex-col">
    <div class="relative text-4xl md:text-6xl mt-[-0.9em]">
      {
        data.imagotypeUrl && (
          <Image
            src={data.imagotypeUrl}
            alt="Osteosalix Logo"
            width={200}
            height={50}
            class="absolute right-[0.35em] w-[0.9em] h-[0.9em] top-[-0.9em]"
          />
        )
      }
      <div class="uppercase" set:html={data.title} />
    </div>
    <h1 class="!text-2xl text-gray tracking-wider mt-3 px-4 text-center md:px-0 font-[mobile-sans]">{data.subtitle}</h1>
  </div>
  <div class="absolute top-0 left-0 w-full z-[1] h-screen opacity-50">
    <Image alt="Osteosalix Portada" src={data.bgImageUrl} width={1920} height={1080} class="object-cover w-full h-full" />
  </div>
</section>
