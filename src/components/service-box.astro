---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  image: string;
  link: string;
}

const { title, image, link } = Astro.props;
---

<a href={link}>
  <div class="p-9 rounded-xl flex items-center justify-center min-h-[285px] w-full bg-black relative overflow-hidden">
    <h3 class="relative z-[1] text-lg leading-7 tracking-wider text-white uppercase text-center font-[mobile-sans]">{title}</h3>
    <div class="absolute top-0 left-0 w-full h-full z-0 opacity-60">
      <Image
        alt={`Tratamiento de ${title}`}
        src={image}
        width={600}
        height={400}
        class="object-cover w-full h-full"
      />
    </div>
  </div>
</a>
