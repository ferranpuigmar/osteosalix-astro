---
import logoSvg from "@/images/logo-icon.svg?raw";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  viewBox="0 0 118 118"
  fill="currentColor"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  set:html={logoSvg.replace(/^<svg[^>]*>|<\/svg>$/g, "")}
/>
