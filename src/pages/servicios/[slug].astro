---
import BaseLayout from '@/layouts/base-layout.astro';
import ContactSection from '@/components/shared/contact-section.astro';
import ServiceBackground from '@/components/services/service-background.astro';
import ServiceHero from '@/components/services/service-hero.astro';
import TreatmentCards from '@/components/services/treatment-cards.astro';
import CtaInline from '@/components/services/cta-inline.astro';
import MethodSteps from '@/components/services/method-steps.astro';
import { getAllServices, getServiceBySlug } from '@/pages/api/services-list';

export async function getStaticPaths() {
  const entries = await getAllServices();
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { slug: entry.slug },
  }));
}

const { slug } = Astro.props;
const service = await getServiceBySlug(slug);

if (!service) {
  return Astro.redirect('/404');
}

const { title, description, descriptionHtml, titleImage, treatments, ctaTitle, ctaDescription, methodSteps } = service;
const heroImage = titleImage ?? '/images/hero-service-design.jpg';
---

<BaseLayout title={title} description={description}>
  <main>
    <ServiceBackground image={heroImage} alt={title}>
      <ServiceHero title={title} description={descriptionHtml ?? description} />
      <TreatmentCards treatments={treatments ?? []} />
    </ServiceBackground>
    <CtaInline title={ctaTitle ?? ''} description={ctaDescription ?? ''} />
    <MethodSteps steps={methodSteps ?? []} />
    <ContactSection />
  </main>
</BaseLayout>
