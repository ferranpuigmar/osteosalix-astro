---
import BaseLayout from "@/layouts/base-layout.astro";
import CenterHero from "@/components/centers/center-hero.astro";
import GalleryCarousel from "@/components/centers/gallery-carousel.astro";
import CenterServices from "@/components/centers/center-services.astro";
import { getAllCenters, getCenterBySlug } from "@/pages/api/centers/[slug]";
import ContactSection from "@/components/shared/contact-section.astro";

export async function getStaticPaths() {
  const entries = await getAllCenters();
  return entries.map((center) => ({
    params: { slug: center.slug },
    props: { slug: center.slug },
  }));
}

const { slug } = Astro.props;
const center = await getCenterBySlug(slug);

if (!center) {
  return Astro.redirect("/404");
}
---

<BaseLayout title={`${center.name} | Osteosalix`} description={center.subtitle}>
  <main>
    <CenterHero center={center} />
    <GalleryCarousel images={center.galleryImages} title={center.name} />
    <CenterServices services={center.services} />
    <ContactSection />
  </main>
</BaseLayout>
